---
import Layout from './Layout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;

const authHeroSrc =
  'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1600&q=80';
---

<Layout title={title}>
  <div class="flex min-h-screen flex-col bg-white">
    <header class="shrink-0 border-b border-slate-200 bg-white">
      <div class="mx-auto flex h-14 items-center justify-center px-4">
        <a
          href="/"
          class="flex items-center justify-center transition-opacity hover:opacity-85"
          aria-label="Ir a inicio"
        >
          <img src="/images/logo.png" alt="LDH" class="h-8 w-auto sm:h-9" width="120" height="36" />
        </a>
      </div>
    </header>

    <div class="flex min-h-0 flex-1 flex-col md:flex-row">
      <div class="relative hidden min-h-[220px] md:block md:min-h-0 md:w-1/2">
        <img
          src={authHeroSrc}
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          width="1600"
          height="1067"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-0 bg-slate-900/10" aria-hidden="true"></div>
      </div>

      <div
        class="flex w-full flex-1 items-center justify-center px-6 py-12 sm:px-10 md:w-1/2 md:py-16 lg:px-16"
      >
        <div class="w-full max-w-md">
          <slot />
        </div>
      </div>
    </div>
  </div>
</Layout>
