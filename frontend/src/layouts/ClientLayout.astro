---
import Layout from './Layout.astro';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const cur = Astro.url.pathname;
const nav = [
  { href: '/cuenta', label: 'Inicio' },
  { href: '/cuenta/mis-envios', label: 'Mis envíos' },
  { href: '/cuenta#enviar', label: 'Nuevo envío' },
  { href: '/cuenta/seguimiento', label: 'Seguimiento' },
  { href: '/cuenta/oficinas', label: 'Oficinas' },
] as const;

function navClass(href: string) {
  if (cur === href) return 'bg-white/15 text-white font-semibold';
  return 'text-slate-200 hover:bg-white/10';
}
---

<Layout title={title ?? 'Mi cuenta LDH'}>
  <div class="flex min-h-screen bg-slate-100">
    <aside class="flex w-56 shrink-0 flex-col bg-ldh-navy text-white">
      <div class="border-b border-white/10 px-4 py-5">
        <a href="/cuenta" class="text-lg font-bold">Mi cuenta</a>
        <p class="text-xs text-slate-200">Área cliente LDH</p>
      </div>
      <nav class="flex flex-1 flex-col gap-1 p-3" aria-label="Cuenta">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={['rounded-md px-3 py-2 text-sm transition', navClass(item.href)]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="border-t border-white/10 p-3 text-xs">
        <a href="/envio/paso-1" class="block rounded-md px-3 py-2 text-slate-100 hover:bg-white/10">
          Asistente de envío (demo)
        </a>
        <button
          type="button"
          class="mt-1 w-full rounded-md px-3 py-2 text-left text-slate-100 hover:bg-white/10"
          id="ldh-client-logout"
        >
          Cerrar sesión
        </button>
      </div>
    </aside>
    <main class="flex-1 p-6 lg:p-8">
      <slot />
    </main>
  </div>
  <script>
    document.getElementById('ldh-client-logout')?.addEventListener('click', () => {
      localStorage.removeItem('ldh_token');
      location.href = '/login';
    });
  </script>
</Layout>
