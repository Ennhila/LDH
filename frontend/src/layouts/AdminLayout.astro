---
import Layout from './Layout.astro';

interface Props {
  title?: string;
}

const { title = 'Administración LDH' } = Astro.props;
const cur = Astro.url.pathname;

const nav = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/oficinas', label: 'Oficinas' },
  { href: '/admin/repartidores', label: 'Repartidores' },
  { href: '/admin/envios', label: 'Envíos' },
] as const;

const priceSub = [
  { href: '/admin/prices/zones', label: 'Gerente de zona' },
  { href: '/admin/prices/matrix', label: 'Matriz de precios' },
] as const;

function navClass(href: string) {
  if (cur === href) return 'bg-white/15 text-white font-semibold';
  return 'text-slate-200 hover:bg-white/10';
}

function subNavClass(href: string) {
  if (cur === href || cur.startsWith(href + '/')) return 'bg-white/15 text-white font-semibold';
  return 'text-slate-200 hover:bg-white/10';
}
---

<Layout title={title}>
  <div class="flex min-h-screen bg-slate-100">
    <aside class="flex w-60 shrink-0 flex-col bg-ldh-navy-dark text-white">
      <div class="border-b border-white/10 px-4 py-5">
        <a href="/admin" class="text-lg font-bold tracking-tight">LDH Admin</a>
        <p class="mt-1 text-xs text-slate-300">Panel de gestión</p>
      </div>
      <nav class="flex flex-1 flex-col gap-1 p-3" aria-label="Admin">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={['flex items-center gap-2 rounded-md px-3 py-2 text-sm transition', navClass(item.href)]}
            >
              <span class="text-ldh-gold" aria-hidden="true">
                •
              </span>
              {item.label}
            </a>
          ))
        }
        <div class="mt-3 px-3 text-[10px] font-bold tracking-wider text-slate-400 uppercase">Precio</div>
        {
          priceSub.map((item) => (
            <a
              href={item.href}
              class:list={['ml-2 flex items-center gap-2 rounded-md px-3 py-2 text-sm transition', subNavClass(item.href)]}
            >
              <span class="text-ldh-gold text-xs" aria-hidden="true">
                ›
              </span>
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="border-t border-white/10 p-3 text-xs text-slate-400">
        <a href="/" class="block rounded-md px-3 py-2 text-slate-200 hover:bg-white/10">
          Volver al sitio
        </a>
        <button
          type="button"
          class="mt-1 w-full rounded-md px-3 py-2 text-left text-slate-200 hover:bg-white/10"
          id="ldh-admin-logout"
        >
          Cerrar sesión
        </button>
      </div>
    </aside>
    <div class="flex min-h-screen flex-1 flex-col">
      <main class="flex-1 p-6 lg:p-8">
        <slot />
      </main>
    </div>
  </div>
  <script>
    document.getElementById('ldh-admin-logout')?.addEventListener('click', () => {
      localStorage.removeItem('ldh_token');
      location.href = '/login';
    });
  </script>
</Layout>
