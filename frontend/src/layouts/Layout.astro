---
import '../styles/global.css';
import { FloatingChatWidget } from '../components/chat/FloatingChatWidget';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'LDH — Paquetería y lockers',
  description = 'Seguimiento de envíos, lockers 24/7 y envíos nacionales e internacionales.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <FloatingChatWidget client:load />
  </body>
</html>
