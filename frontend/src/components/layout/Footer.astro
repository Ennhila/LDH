---
const year = new Date().getFullYear();

const paraTi = [
  { label: 'Seguimiento de envío', href: '#tracking' },
  { label: 'Recibir', href: '#recibir' },
  { label: 'Enviar', href: '#enviar' },
];

const paraEmpresa = [
  { label: 'Enviar', href: '#b2b-enviar' },
  { label: 'Ecommerce', href: '#ecommerce' },
  { label: 'Marketing', href: '#marketing' },
];

const legal = [
  { label: 'Política de cookies', href: '#cookies' },
  { label: 'Aviso legal', href: '#aviso' },
  { label: 'Privacidad web', href: '#privacidad' },
  { label: 'Alerta seguridad', href: '#seguridad' },
  { label: 'Accesibilidad', href: '#accesibilidad' },
  { label: 'Configurador de cookies', href: '#config-cookies' },
];

const socialLinks = [
  { href: '#facebook', label: 'Facebook', src: '/images/facebook_1384053.png' },
  { href: '#instagram', label: 'Instagram', src: '/images/icons8-instagram-48.png' },
  { href: '#twitter', label: 'X (Twitter)', src: '/images/icons8-x-50.png' },
  { href: '#linkedin', label: 'LinkedIn', src: '/images/linkedin_1384062.png' },
  { href: '#youtube', label: 'YouTube', src: '/images/youtube_1384060.png' },
];

/** Logos en public/images (Visa, Maestro/MC, Amex, PayPal). */
const paymentLogos = [
  { src: '/images/visa.svg', alt: 'Visa' },
  { src: '/images/maestro.svg', alt: 'Mastercard / Maestro' },
  { src: encodeURI('/images/log amex.svg'), alt: 'American Express' },
  { src: '/images/paypal.svg', alt: 'PayPal' },
];
---

<footer class="bg-slate-100 text-ldh-navy" id="mas-info">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1fr_1fr_minmax(0,1.2fr)]">
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-slate-500">Para ti</h3>
        <ul class="mt-4 space-y-3 text-sm font-semibold">
          {
            paraTi.map((item) => (
              <li>
                <a href={item.href} class="transition-colors hover:text-ldh-orange">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-slate-500">Para tu empresa</h3>
        <ul class="mt-4 space-y-3 text-sm font-semibold">
          {
            paraEmpresa.map((item) => (
              <li>
                <a href={item.href} class="transition-colors hover:text-ldh-orange">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="lg:text-right">
        <a
          href="#atencion"
          class="inline-flex items-center gap-2 text-sm font-bold text-ldh-navy hover:text-ldh-orange"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-ldh-orange"
            aria-hidden="true"
          >
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          Atención al cliente
        </a>
        <div class="mt-6 flex flex-wrap gap-3 lg:justify-end" aria-label="Redes sociales">
          {
            socialLinks.map((s) => (
              <a
                href={s.href}
                class="flex h-10 w-10 items-center justify-center rounded-lg bg-white p-2 shadow-sm ring-1 ring-slate-200/80 transition-opacity hover:opacity-90 hover:ring-ldh-orange/40"
                aria-label={s.label}
              >
                <img src={s.src} alt="" class="h-6 w-6 object-contain" width="24" height="24" loading="lazy" />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-8 border-t border-slate-200/80 pt-10 lg:flex-row lg:items-center lg:justify-between"
      id="descarga"
    >
      <div>
        <p class="text-sm font-bold text-ldh-navy">Descarga la app LDH</p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="#app-store"
            class="inline-flex min-h-11 items-center overflow-hidden rounded-lg ring-1 ring-slate-200/80 transition-opacity hover:opacity-95"
            aria-label="Descargar en App Store"
          >
            <img
              src="/images/apple_store.jpg"
              alt=""
              class="h-11 w-auto max-w-[140px] object-contain"
              width="140"
              height="44"
              loading="lazy"
            />
          </a>
          <a
            href="#google-play"
            class="inline-flex min-h-11 items-center overflow-hidden rounded-lg ring-1 ring-slate-200/80 transition-opacity hover:opacity-95"
            aria-label="Descargar en Google Play"
          >
            <img
              src="/images/google_play.jpg"
              alt=""
              class="h-11 w-auto max-w-[156px] object-contain"
              width="156"
              height="44"
              loading="lazy"
            />
          </a>
        </div>
      </div>
      <div class="lg:text-right">
        <p class="text-sm font-bold text-ldh-navy">Métodos de pago</p>
        <div class="mt-4 flex flex-wrap items-center gap-3 lg:justify-end" aria-label="Métodos de pago aceptados">
          {
            paymentLogos.map((p) => (
              <span class="inline-flex h-9 items-center rounded-md bg-white px-2 py-1 shadow-sm ring-1 ring-slate-200/80">
                <img src={p.src} alt={p.alt} class="h-6 w-auto max-w-[52px] object-contain" loading="lazy" />
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="bg-slate-900 py-8 text-slate-300">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav
        class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-center text-xs font-medium sm:text-sm"
        aria-label="Legal"
      >
        {
          legal.map((item) => (
            <a href={item.href} class="hover:text-white">
              {item.label}
            </a>
          ))
        }
      </nav>
      <p class="mt-6 text-center text-[11px] text-slate-500">
        © {year} LDH. Todos los derechos reservados. Contenido de demostración.
      </p>
    </div>
  </div>
</footer>
